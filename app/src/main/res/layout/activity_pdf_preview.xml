<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PdfPreviewActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- PDF PREVIEW AREA -->

        <ImageView
            android:id="@+id/pdfImage"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:scaleType="fitCenter"
            android:background="#eeeeee"/>

        <!-- FILE NAME -->

        <TextView
            android:id="@+id/txtPdfName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PDF Name"
            android:textSize="18sp"
            android:layout_marginBottom="20dp"/>

        <!-- FREE / PREMIUM -->
        <RadioGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <RadioButton
                android:id="@+id/radioFree"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Free"
                android:textSize="16sp"
                android:textColor="#000000"
                android:buttonTint="#000000"
                android:checked="true"
                android:padding="8dp"/>

            <RadioButton
                android:id="@+id/radioPremium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium"
                android:textSize="16sp"
                android:textColor="#000000"
                android:buttonTint="#000000"
                android:layout_marginStart="20dp"
                android:padding="8dp"/>
        </RadioGroup>

        <!-- ⭐ NEW: TITLE INPUT -->
        <EditText
            android:id="@+id/etPdfTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter PDF title..."
            android:layout_marginTop="12dp"
            android:padding="10dp"
            android:background="@android:drawable/edit_text"
            android:textColor="#000"
            android:textColorHint="#888"/>

        <Button
            android:id="@+id/btnConfirmUpload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm Upload" />

        <!-- ===== UPLOAD PROGRESS BAR ===== -->

        <ProgressBar
            android:id="@+id/uploadProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/uploadPercentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="16sp"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>