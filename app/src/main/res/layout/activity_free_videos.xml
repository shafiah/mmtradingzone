<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECE7F6"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="20dp">

    <!-- Welcome Heading -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to ABITI"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="30dp"/>

    <!-- Main Container -->

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Introduction Video

            <TextView
                android:id="@+id/video1"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#F0F0F0"
                android:text="▶ Introduction Video"
                android:textSize="18sp"
                android:gravity="center_vertical"
                android:padding="15dp"
                android:layout_marginBottom="16dp"/>  -->

            <!-- Basics Video

            <TextView
                android:id="@+id/video2"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#F0F0F0"
                android:text="▶ Basics Video"
                android:textSize="18sp"
                android:gravity="center_vertical"
                android:padding="15dp"
                android:layout_marginBottom="30dp"/>  -->

            <!-- Free Videos Button -->

            <Button
                android:id="@+id/btnFreeVideos"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Free Videos"
                android:layout_marginBottom="16dp"/>

            <!-- Paid Videos Button -->

            <Button
                android:id="@+id/btnPaidVideos"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Premium Videos"/>

            <!-- FREE IMAGES BUTTON -->
            <Button
                android:id="@+id/btnFreeImages"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Free Images"
                android:layout_marginTop="10dp"/>

            <!-- PAID IMAGES BUTTON -->
            <Button
                android:id="@+id/btnPaidImages"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Premium Images"
                android:layout_marginTop="10dp"/>

            <!-- FREE PDF BUTTON -->
            <Button
                android:id="@+id/btnFreePdf"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Free Pdf"
                android:layout_marginTop="10dp"/>

            <!-- PAID PDF BUTTON -->
            <Button
                android:id="@+id/btnPaidPdf"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Premium Pdf"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>