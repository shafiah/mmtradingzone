<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.navigation.NavigationView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:layout_gravity="start">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@android:color/white">

            <!-- PROFILE IMAGE -->
            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_user"
                android:contentDescription="@string/profile" />

            <!-- NAME -->
            <TextView
                android:id="@+id/txtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/user_name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_gravity="center" />

            <!-- ORG CODE -->
            <TextView
                android:id="@+id/txtOrgCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/org_code"
                android:textColor="#777777"
                android:layout_marginTop="4dp"
                android:layout_gravity="center" />

            <!-- MENU LIST -->
            <LinearLayout
                android:id="@+id/menuContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">

                <!-- ⭐ IDs ADDED -->
                <include layout="@layout/drawer_item" android:id="@+id/menuOffline"/>
                <include layout="@layout/drawer_item" android:id="@+id/menuFree"/>
                <include layout="@layout/drawer_item" android:id="@+id/menuTestimonial"/>
                <include layout="@layout/drawer_item" android:id="@+id/menuEditProfile"/>
                <include layout="@layout/drawer_item" android:id="@+id/menuSettings"/>
                <include layout="@layout/drawer_item" android:id="@+id/menuHowTo"/>
                <include layout="@layout/drawer_item" android:id="@+id/menuPrivacy"/>

            </LinearLayout>
            <!-- LOGOUT -->
            <TextView
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/logout"
                android:padding="12dp"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />



            <!-- SHARE BUTTON -->
            <Button
                android:id="@+id/btnShare"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/share_facebook"
                android:textColor="@android:color/white"
                android:backgroundTint="#1877F2"
                android:layout_marginTop="24dp" />


        </LinearLayout>

    </ScrollView>

</com.google.android.material.navigation.NavigationView>