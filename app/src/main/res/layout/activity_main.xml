<?xml version="1.0" encoding="utf-8"?>  <androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true"
    android:focusableInTouchMode="true"

    >

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 🔵 TOP APP BAR -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="6dp">

            <!--  <include layout="@layout/toolbar_layout"/> -->
        </com.google.android.material.appbar.AppBarLayout>
        <!-- 📜 SCROLL CONTENT -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="72dp"
            android:layout_marginBottom="56dp"
            android:fillViewport="true"
            android:background="#ECE7F6"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/screen_padding" >

                <!-- WHAT DO YOU WANT TO LEARN -->
            <!--    <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What do you want to learn?"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"/>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <ImageView
                        android:id="@+id/ivTopYoutube"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_youtube"
                        android:contentDescription="YouTube"/>

                    <Space
                        android:layout_width="32dp"
                        android:layout_height="1dp"/>

                    <ImageView
                        android:id="@+id/ivTopTelegram"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_telegram"
                        android:contentDescription="Telegram"/>
                </LinearLayout>  -->

                <!-- ✅ NEW: LOGO CARD (SAME AS ALL COURSE CARD) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">



                        <!-- 🔥 LOGO ICON (same size as All Course icon) -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/login_logo"
                            android:scaleType="fitXY"
                            android:contentDescription="App Logo"/>



                </com.google.android.material.card.MaterialCardView>

                <!-- ✅ NEW HEADER START -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="24dp">

                    <!-- 🔥 APP LOGO (drawer wala) -->

                    <!-- 🔥 WELCOME TEXT
                    <TextView
                        android:id="@+id/txtWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"/> -->

                    <!-- 🔥 USER NAME (DYNAMIC) -->
                    <TextView
                        android:id="@+id/txtWelcomeUser"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome, User"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginTop="8dp"/>

                    <!-- 🔥 SUBTITLE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Explore our courses and resources"
                        android:textSize="13sp"
                        android:textColor="#666"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- ✅ NEW HEADER END -->

                <!-- WHAT ARE YOU LOOKING FOR -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What are you looking for?"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"/>

                <!-- 2x2 GRID -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="1"
                    android:useDefaultMargins="true">

                    <!-- CARD 1 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/layoutAllCourse"
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView

                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_courses"
                                app:tint="#FF0000"
                                android:contentDescription="All Courses"/>

                            <!-- TITLE -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="All Courses"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="#000"
                                android:gravity="center"/>

                            <!-- SUBTITLE -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Browse all available courses"
                                android:textSize="12sp"
                                android:textColor="#888"
                                android:gravity="center"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- CARD 2 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardFileUpload"
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_upload"
                                app:tint="#FF0000"
                                android:contentDescription="Trading Basics"/>

                            <!-- TITLE -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="File Upload"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="#000"
                                android:gravity="center"/>

                            <!-- SUBTITLE -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Upload videos, PDFs and images"
                                android:textSize="12sp"
                                android:textColor="#888"
                                android:gravity="center"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- CARD 3
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_advanced"
                                app:tint="#FF0000"
                                android:contentDescription="Advance Strategy"/>

                            <TextView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:text="Advance Strategy"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>  -->

                    <!-- CARD 4
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/ivGridInstagram"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_instagram"
                                android:textStyle="bold"
                                android:contentDescription="Instagram"/>

                            <TextView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:text="Instagram"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>  -->

                </GridLayout>

                <!-- ⚠ NOTICE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/transparent">

                    <!-- MARKET WARNING CONTAINER -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:elevation="0dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="0dp">

                            <!-- TEXT -->
                            <TextView
                                android:id="@+id/tvMarketWarning"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="BASIC COURSES FOR TRADING RS.499."
                                android:textSize="16sp"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:gravity="center"/>

                            <!-- ============================= -->
                            <!-- ⭐ PREMIUM CARD (NEW DESIGN) -->
                            <!-- ============================= -->
                            <!-- ✅ NEW: PREMIUM BANNER CARD -->
                            <!-- ✅ CLEAN & FIXED PREMIUM BANNER -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardPrimeBanner"
                                android:layout_width="match_parent"
                                android:layout_height="180dp"

                                android:layout_marginBottom="16dp"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="6dp">

                                <ImageView
                                    android:id="@+id/imgPrimeBanner"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/prime_banner"
                                    android:scaleType="fitXY"
                                    android:contentDescription="banner"/>

                            </com.google.android.material.card.MaterialCardView>


                            <!-- BUY BUTTON -->
                            <Button
                                android:id="@+id/btnBuyNow"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Buy Now"
                                android:backgroundTint="#03A9F4"
                                android:layout_marginTop="16dp" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- CONNECT WITH US -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connect with us"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginBottom="40dp">

                    <ImageView
                        android:id="@+id/ivBottomYoutube"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_youtube"
                        android:contentDescription="YouTube"/>

                    <Space
                        android:layout_width="24dp"
                        android:layout_height="1dp"/>

                    <ImageView
                        android:id="@+id/ivBottomInstagram"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_instagram"
                        android:contentDescription="Instagram"/>

                    <Space
                        android:layout_width="24dp"
                        android:layout_height="1dp"/>

                    <ImageView
                        android:id="@+id/ivBottomTelegram"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_telegram"
                        android:contentDescription="Telegram"/>
                    <!--
                        <Button
                            android:id="@+id/btnLogout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Logout"/>
                            -->
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ⬇️ BOTTOM NAV
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="0dp"
            android:paddingBottom="8dp"
            android:fitsSystemWindows="true"

            app:menu="@menu/bottom_menu"/>  -->

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
    <!-- 🧩 DRAWER CONTENT -->
    <include

        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        layout="@layout/drawer_layout"/>

</androidx.drawerlayout.widget.DrawerLayout>